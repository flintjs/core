{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "target": "ES2020",
        "esModuleInterop": true,
        "resolveJsonModule": true
    },
    "include": ["src/**/*"],
    "references": [
        { "path": "../utils" }
    ]
}
