{
    "name": "flint.js",
    "private": true,
    "license": "Apache-2.0",
    "scripts": {
        "core:build": "pnpm --filter @flint.js/core build",
        "logger:build": "pnpm --filter @flint.js/logger build",
        "i18n:build": "pnpm --filter @flint.js/i18n build",
        "utils:build": "pnpm --filter @flint.js/utils build",
        "docs:dev": "cd apps/docs && mint dev"
    },
    "devDependencies": {
        "prettier": "^3.0.0",
        "ts-node": "^10.9.1",
        "typescript": "^5.1.6"
    },
    "packageManager": "pnpm@9.14.2",
    "engines": {
        "node": ">=18.0.0"
    }
}
